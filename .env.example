# --- Backend (dibaca oleh function di /api saat runtime) ---
MONGODB_URI=mongodb+srv://user:password@cluster0.mongodb.net/kelasx6?retryWrites=true&w=majority
CLASS_GROUP_ID=6281234567890-1234567890@g.us
ADMIN_API_KEY=ganti-dengan-kunci-rahasia-acak
KAS_TARGET=3000000

# ALLOWED_ORIGIN hanya perlu diisi kalau ada yang memanggil /api dari domain lain.
# Untuk pemakaian normal (frontend & backend satu deployment yang sama), boleh dikosongkan.
ALLOWED_ORIGIN=

# --- Frontend (dibaca oleh Vite saat build, harus diawali VITE_) ---
# Dikosongkan/pakai "" supaya frontend memanggil /api secara relatif ke domain yang sama.
# Isi dengan URL lengkap hanya kalau frontend dan backend sengaja dipisah ke deployment berbeda.
VITE_API_URL=
